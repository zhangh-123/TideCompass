.shell {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #e9eef3;
}

.top-bar {
  padding: 16rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #e6e6e6;
}

.title-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}

.chat {
  flex: 1;
  padding: 24rpx;
  box-sizing: border-box;
}

.chat-end {
  height: 24rpx;
}

.msg-row {
  display: flex;
  margin-bottom: 20rpx;
}

.msg-row.user {
  justify-content: flex-end;
}

.msg-row.assistant {
  justify-content: flex-start;
}

.bubble {
  max-width: 82%;
  padding: 18rpx 22rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  line-height: 1.55;
  word-break: break-word;
  white-space: pre-wrap;
}

.msg-row.user .bubble {
  background: #95ec69;
  color: #111;
  border-top-right-radius: 4rpx;
}

.msg-row.assistant .bubble {
  background: #fff;
  color: #222;
  border-top-left-radius: 4rpx;
  border: 1rpx solid #e8e8e8;
}

.composer {
  display: flex;
  align-items: flex-end;
  gap: 16rpx;
  padding: 16rpx 20rpx calc(16rpx + env(safe-area-inset-bottom));
  background: #f7f7f7;
  border-top: 1rpx solid #e0e0e0;
}

.safe-bottom {
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

.composer-input {
  flex: 1;
  min-height: 72rpx;
  max-height: 220rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  background: #fff;
  border-radius: 12rpx;
  border: 1rpx solid #ddd;
  box-sizing: border-box;
}

.send-btn {
  flex-shrink: 0;
  margin: 0 !important;
  align-self: flex-end;
}

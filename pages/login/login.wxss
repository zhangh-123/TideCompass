.login-root {
  min-height: 100vh;
  background: #f8fafc;
  box-sizing: border-box;
  padding: 80rpx 40rpx 120rpx;
  font-family:
    Inter,
    -apple-system,
    BlinkMacSystemFont,
    'PingFang SC',
    'Source Han Sans SC',
    'Noto Sans SC',
    sans-serif;
}

.login-inner {
  max-width: 686rpx;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 85vh;
  justify-content: space-between;
}

.brand-mark {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 48rpx;
}

/* 简约罗盘线性图标 */
.compass-ico {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 48rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.compass-ring {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 4rpx solid #1e3a8a;
  box-sizing: border-box;
  opacity: 0.9;
}

.compass-needle {
  position: absolute;
  width: 6rpx;
  height: 56rpx;
  background: linear-gradient(180deg, #10b981 0%, #1e3a8a 100%);
  border-radius: 4rpx;
  transform: rotate(-35deg);
  top: 50%;
  margin-top: -56rpx;
  left: 50%;
  margin-left: -3rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.brand-title {
  font-size: 56rpx;
  font-weight: 700;
  color: #1e3a8a;
  letter-spacing: 1rpx;
  margin-bottom: 16rpx;
}

.brand-sub {
  font-size: 28rpx;
  color: #64748b;
  font-weight: 400;
}

.login-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: env(safe-area-inset-bottom);
}

.wx-login-btn {
  width: 80%;
  margin: 0;
  padding: 28rpx 32rpx;
  border-radius: 24rpx;
  background: #07c160;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.25);
}

.wx-login-btn::after {
  border: none;
}

.wx-login-btn[disabled] {
  opacity: 0.65;
}

.wx-login-inner {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.wx-ico {
  width: 40rpx;
  height: 40rpx;
  border-radius: 12rpx;
  background: #ffffff;
  position: relative;
  flex-shrink: 0;
}

.wx-ico::before,
.wx-ico::after {
  content: '';
  position: absolute;
  background: #07c160;
  border-radius: 2rpx;
}

.wx-ico::before {
  width: 28rpx;
  height: 8rpx;
  left: 6rpx;
  top: 10rpx;
  transform: rotate(-12deg);
}

.wx-ico::after {
  width: 20rpx;
  height: 8rpx;
  left: 10rpx;
  top: 22rpx;
  transform: rotate(8deg);
}

.wx-login-text {
  font-size: 32rpx;
  font-weight: 500;
  color: #ffffff;
}

.legal-line {
  margin-top: 36rpx;
  padding: 0 16rpx;
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  justify-content: center;
  align-items: center;
  gap: 4rpx;
}

.legal-text {
  font-size: 24rpx;
  color: #94a3b8;
  line-height: 1.5;
}

.legal-link {
  font-size: 24rpx;
  color: #1e3a8a;
  line-height: 1.5;
}

.tap-active {
  transition:
    transform 0.15s ease,
    opacity 0.15s ease;
}

.tap-active:active {
  transform: scale(0.98);
  opacity: 0.92;
}

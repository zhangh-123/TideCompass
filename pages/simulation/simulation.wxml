<view class="page">
  <view class="card" wx:if="{{!isVip}}">
    <text class="title">会员专属</text>
    <text class="desc">现金流模拟仅对会员开放，开通后可进行多方案对比。</text>
    <button class="vip-btn" bindtap="goVip">去开通会员</button>
  </view>

  <block wx:else>
    <view class="card">
      <text class="title">模拟参数</text>
      <view class="field"><text>失业持续月数</text><input class="input" type="number" value="{{form.unemploymentMonths}}" data-k="unemploymentMonths" bindinput="onInput" /></view>
      <view class="field"><text>失业期间支出减少%</text><input class="input" type="digit" value="{{form.expenseReducePct}}" data-k="expenseReducePct" bindinput="onInput" /></view>
      <view class="field"><text>当前月收入（元）</text><input class="input" type="digit" value="{{form.currentMonthlyIncome}}" data-k="currentMonthlyIncome" bindinput="onInput" /></view>
      <view class="field"><text>当前月支出（元）</text><input class="input" type="digit" value="{{form.currentMonthlyExpense}}" data-k="currentMonthlyExpense" bindinput="onInput" /></view>
      <view class="field"><text>重新就业月收入（元）</text><input class="input" type="digit" value="{{form.newMonthlyIncome}}" data-k="newMonthlyIncome" bindinput="onInput" /></view>
      <view class="field"><text>副业/培训总投资（元）</text><input class="input" type="digit" value="{{form.extraInvestment}}" data-k="extraInvestment" bindinput="onInput" /></view>
      <view class="field">
        <text>投资方式</text>
        <picker mode="selector" range="{{investModes}}" value="{{investModeIndex}}" bindchange="onInvestModeChange">
          <view class="picker">{{investModes[investModeIndex]}}</view>
        </picker>
      </view>
      <view class="field" wx:if="{{form.investmentMode==='installment'}}">
        <text>分期月数</text><input class="input" type="number" value="{{form.installmentMonths}}" data-k="installmentMonths" bindinput="onInput" />
      </view>
      <view class="btn-row">
        <button class="run-btn" bindtap="onRun" loading="{{running}}">运行模拟</button>
        <button class="save-btn" bindtap="onSavePlan" loading="{{saving}}">保存方案</button>
      </view>
    </view>

    <view class="card" wx:if="{{chartReady}}">
      <text class="title">未来12个月净值走势</text>
      <view class="chart-box">
        <ec-canvas id="sim-chart" class="chart-ec" style="width:100%;height:100%;display:block;" canvas-id="sim-chart-canvas" echarts="{{ echartsLib }}" ec="{{ ec }}" />
      </view>
    </view>

    <view class="card">
      <view class="head-line">
        <text class="title">已保存方案（最多5个）</text>
        <button class="small" size="mini" bindtap="loadPlans">刷新</button>
      </view>
      <block wx:for="{{savedPlans}}" wx:key="_id">
        <view class="plan-row">
          <view class="plan-main">
            <text>{{item.name}}</text>
            <text class="sub">{{item.createdAtText}}</text>
            <text class="sub">{{item.reportText ? 'AI报告：已生成' : 'AI报告：未生成'}}</text>
          </view>
          <view class="plan-actions">
            <button class="small" size="mini" data-id="{{item._id}}" bindtap="toggleCompareA">{{compareAId===item._id?'A已选':'设为A'}}</button>
            <button class="small" size="mini" data-id="{{item._id}}" bindtap="toggleCompareB">{{compareBId===item._id?'B已选':'设为B'}}</button>
            <button class="small" size="mini" data-id="{{item._id}}" bindtap="openAIReport">{{item.reportText?'查看报告':'生成报告'}}</button>
            <button class="small danger" size="mini" data-id="{{item._id}}" bindtap="removePlan">删除</button>
          </view>
        </view>
      </block>
      <button class="run-btn" bindtap="onCompare" disabled="{{!compareAId || !compareBId}}">对比 A / B 方案</button>
    </view>
  </block>
</view>

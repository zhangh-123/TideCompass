<view class="bind-root">
  <text class="guide-text">绑定手机号，保障你的财务数据安全</text>

  <view class="form-card">
    <text class="field-label"><text class="req">*</text>手机号</text>
    <view class="merge-row {{phoneFocus ? 'is-focus' : ''}}">
      <input
        class="merge-input"
        type="number"
        maxlength="11"
        placeholder="请输入11位手机号"
        placeholder-class="ph"
        value="{{phone}}"
        bindinput="onPhoneInput"
        bindfocus="onPhoneFocus"
        bindblur="onPhoneBlur"
      />
      <button
        class="code-btn"
        hover-class="none"
        disabled="{{countdown > 0 || sendingCode}}"
        bindtap="onSendCode"
      >
        {{countdown > 0 ? countdown + 's' : '获取验证码'}}
      </button>
    </view>
    <text class="field-error" wx:if="{{phoneError}}">{{phoneError}}</text>

    <view class="field-gap"></view>

    <text class="field-label"><text class="req">*</text>验证码</text>
    <view class="solo-field {{codeFocus ? 'is-focus' : ''}}">
      <input
        class="solo-input"
        type="number"
        maxlength="6"
        placeholder="请输入6位验证码"
        placeholder-class="ph"
        value="{{code}}"
        bindinput="onCodeInput"
        bindfocus="onCodeFocus"
        bindblur="onCodeBlur"
      />
    </view>
    <text class="field-error" wx:if="{{codeError}}">{{codeError}}</text>

    <button
      class="submit-btn tap-active"
      hover-class="none"
      loading="{{binding}}"
      disabled="{{binding || !canBind}}"
      bindtap="onConfirmBind"
    >
      确认绑定
    </button>
  </view>
</view>

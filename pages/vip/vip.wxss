.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background: #f3f6fb;
}
.card {
  background: #fff;
  border-radius: 18rpx;
  border: 1rpx solid #e5e7eb;
  padding: 24rpx;
  margin-bottom: 18rpx;
}
.title { display: block; font-size: 36rpx; font-weight: 700; color: #0f172a; }
.desc { display: block; margin-top: 12rpx; line-height: 1.5; font-size: 25rpx; color: #475569; }
.status { display: block; margin-top: 14rpx; color: #1d4ed8; font-size: 24rpx; }
.sec-title { display: block; margin-bottom: 12rpx; font-size: 30rpx; font-weight: 600; color: #111827; }
.item { display: block; color: #334155; font-size: 25rpx; line-height: 1.6; }
.plan-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}
.plan-row:last-child { border-bottom: none; }
.plan-title { display: block; font-size: 28rpx; font-weight: 600; color: #0f172a; }
.plan-sub { display: block; margin-top: 6rpx; font-size: 22rpx; color: #64748b; }
.plan-right { display: flex; align-items: center; gap: 12rpx; }
.price { font-size: 32rpx; font-weight: 700; color: #dc2626; }
.buy-btn {
  border-radius: 12rpx;
  background: #2563eb !important;
  color: #fff !important;
  font-size: 26rpx !important;
  padding: 0 22rpx !important;
}

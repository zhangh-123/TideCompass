.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #eef2f7;
}

.main {
  flex: 1;
  height: 0;
  padding: 20rpx 24rpx 32rpx;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 18rpx;
  padding: 26rpx 22rpx;
  border: 1rpx solid #e5e7eb;
  margin-bottom: 20rpx;
}

.head-card .subtle {
  display: block;
  margin-top: 16rpx;
}

.month-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.month-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #0f172a;
}

.nav-btn {
  width: 72rpx !important;
  height: 72rpx !important;
  padding: 0 !important;
  line-height: 72rpx !important;
  border-radius: 12rpx !important;
  font-size: 36rpx !important;
  background: #f1f5f9 !important;
  color: #334155 !important;
}

.card-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 12rpx;
}

.subtle {
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.45;
}

.subtle.block {
  display: block;
  margin-bottom: 18rpx;
}

.sub-btn {
  margin-top: 8rpx;
  font-size: 26rpx !important;
  background: #eff6ff !important;
  color: #1d4ed8 !important;
  border-radius: 12rpx !important;
}

.row {
  display: flex;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.row:last-child {
  border-bottom: none;
}

.head-row {
  padding-top: 0;
  font-size: 24rpx;
  color: #64748b;
}

.col {
  box-sizing: border-box;
}

.col.cat {
  width: 22%;
  flex-shrink: 0;
  font-size: 26rpx;
  color: #334155;
}

.col.spent {
  width: 38%;
  text-align: right;
  padding-right: 12rpx;
  font-size: 26rpx;
  color: #475569;
}

.col.spent.over {
  color: #dc2626;
  font-weight: 600;
}

.col.cap {
  width: 40%;
  flex: 1;
}

.cap-input {
  width: 100%;
  padding: 14rpx 16rpx;
  font-size: 26rpx;
  background: #f8fafc;
  border-radius: 10rpx;
  border: 1rpx solid #e2e8f0;
  box-sizing: border-box;
}

.save-bar {
  width: 100% !important;
  border-radius: 14rpx !important;
  font-size: 30rpx !important;
}

.bottom-spacer {
  height: 40rpx;
}

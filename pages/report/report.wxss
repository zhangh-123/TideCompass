.report-root {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f8fafc;
  font-family:
    Inter,
    -apple-system,
    BlinkMacSystemFont,
    'PingFang SC',
    'Source Han Sans SC',
    'Noto Sans SC',
    sans-serif;
}

.main {
  flex: 1;
  height: 0;
  padding: 32rpx 32rpx 0;
  box-sizing: border-box;
}

.flow-gap {
  margin-bottom: 40rpx;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  border: 1rpx solid #e2e8f0;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.05);
  box-sizing: border-box;
}

.card-heading {
  font-size: 34rpx;
  font-weight: 600;
  color: #1e293b;
}

.card-heading.sm {
  font-size: 30rpx;
  margin-bottom: 24rpx;
  display: block;
}

.radar-head {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.refresh-soft {
  margin: 0 !important;
  padding: 10rpx 22rpx !important;
  font-size: 26rpx !important;
  line-height: 1.35 !important;
  border-radius: 16rpx !important;
  background: rgba(30, 58, 138, 0.1) !important;
  color: #1e3a8a !important;
  font-weight: 500 !important;
  border: none !important;
}

.refresh-soft::after {
  border: none !important;
}

.radar-intro {
  display: block;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.45;
  margin-bottom: 12rpx;
}

.emotion-line {
  display: block;
  font-size: 26rpx;
  color: #475569;
  line-height: 1.55;
  margin-bottom: 12rpx;
  padding: 16rpx 20rpx;
  background: rgba(16, 185, 129, 0.06);
  border-radius: 16rpx;
  border: 1rpx solid rgba(16, 185, 129, 0.18);
}

.dynamic-hint {
  display: block;
  margin-bottom: 16rpx;
  font-size: 24rpx;
  color: #64748b;
}

.radar-box {
  width: 100%;
  height: 460rpx;
  position: relative;
}

.radar-placeholder {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
  background: rgba(248, 250, 252, 0.92);
  border-radius: 16rpx;
}

.radar-ph-text {
  font-size: 26rpx;
  color: #94a3b8;
}

.radar-ec {
  width: 100%;
  height: 100%;
  display: block;
}

.score-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  margin-top: 24rpx;
}

.score-cell {
  background: #f8fafc;
  border-radius: 16rpx;
  padding: 20rpx 22rpx;
  border: 1rpx solid #e2e8f0;
}

.score-cap {
  display: block;
  font-size: 24rpx;
  color: #64748b;
  margin-bottom: 10rpx;
}

.score-num {
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.2;
}

.score-narrative {
  margin-top: 28rpx;
  padding: 24rpx 22rpx;
  background: #f8fafc;
  border-radius: 18rpx;
  border: 1rpx solid #e2e8f0;
}

.score-narrative-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 16rpx;
}

.score-narrative-body {
  display: block;
  font-size: 24rpx;
  color: #475569;
  line-height: 1.65;
  word-break: break-word;
}

.score-narrative-block {
  margin-bottom: 20rpx;
}

.score-narrative-block:last-child {
  margin-bottom: 0;
}

.tone-mint {
  color: #10b981;
}

.tone-warn {
  color: #f97316;
}

.tone-neutral {
  color: #1e3a8a;
}

/* 资产负债表模块 */
.sheet-card .sheet-module-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 24rpx;
}

.sheet-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #e2e8f0;
}

.sheet-row:last-of-type {
  border-bottom: none;
}

.sheet-highlight {
  margin-top: 8rpx;
  padding-top: 28rpx;
  border-top: 2rpx dashed #e2e8f0;
}

.sheet-k {
  font-size: 28rpx;
  color: #64748b;
}

.sheet-v {
  font-size: 30rpx;
  color: #1e293b;
}

.sheet-v.strong {
  font-weight: 600;
}

.sheet-v.xl {
  font-size: 40rpx;
  font-weight: 700;
}

.nw-pos {
  color: #10b981;
}

.nw-neg {
  color: #f87171;
}

.trend-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 12rpx;
  margin-top: 16rpx;
  padding: 14rpx 18rpx;
  background: #f8fafc;
  border-radius: 16rpx;
}

.trend-icon {
  font-size: 26rpx;
  color: #1e3a8a;
  line-height: 1.5;
}

.trend-text {
  flex: 1;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.5;
}

.sub-head {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-top: 28rpx;
  padding: 16rpx 0;
}

.sub-head-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
}

.sub-head-more {
  font-size: 24rpx;
  color: #1e3a8a;
}

.list-wrap {
  padding-bottom: 8rpx;
}

.list-line {
  display: block;
  font-size: 26rpx;
  color: #334155;
  line-height: 1.55;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.list-line:last-child {
  border-bottom: none;
}

.empty-tip {
  font-size: 24rpx;
  color: #94a3b8;
  padding: 12rpx 0;
}

.insight-card {
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid #e2e8f0;
}

.soft-blue {
  background: linear-gradient(135deg, rgba(30, 58, 138, 0.06) 0%, #ffffff 100%);
}

.soft-coral {
  background: linear-gradient(135deg, rgba(249, 115, 22, 0.06) 0%, #ffffff 100%);
}

.insight-tag {
  display: inline-block;
  font-size: 22rpx;
  color: #1e3a8a;
  background: rgba(30, 58, 138, 0.1);
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  margin-bottom: 14rpx;
}

.insight-tag.tag-coral {
  color: #c2410c;
  background: rgba(249, 115, 22, 0.12);
}

.insight-body {
  display: block;
  font-size: 28rpx;
  color: #334155;
  line-height: 1.65;
}

.bottom-spacer {
  height: calc(160rpx + env(safe-area-inset-bottom));
}

.footer {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 1rpx solid #e2e8f0;
}

.safe-bottom {
  flex-shrink: 0;
}

.share-btn {
  flex: 1;
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 24rpx !important;
  font-size: 28rpx !important;
  font-weight: 500 !important;
  background: rgba(30, 58, 138, 0.08) !important;
  color: #1e3a8a !important;
  border: none !important;
}

.share-btn::after {
  border: none !important;
}

.done-btn {
  flex: 1;
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 24rpx !important;
  font-size: 32rpx !important;
  font-weight: 500 !important;
  color: #ffffff !important;
  background: linear-gradient(135deg, #1e3a8a 0%, #2563eb 100%) !important;
  border: none !important;
}

.done-btn::after {
  border: none !important;
}

.tap-soft:active {
  opacity: 0.9;
  transform: scale(0.99);
}

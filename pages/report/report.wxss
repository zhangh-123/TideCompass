.report-page {
  min-height: 100vh;
  background: #f8f9fa;
  box-sizing: border-box;
  padding-bottom: calc(240rpx + env(safe-area-inset-bottom));
}

.page-loading {
  min-height: 60vh;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #64748b;
  font-size: 28rpx;
}

.main-body {
  padding: 24rpx;
  box-sizing: border-box;
}

.empty-state {
  min-height: 50vh;
  padding: 48rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #64748b;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 32rpx;
}

.empty-btn {
  width: 320rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: #1e3a8a !important;
  color: #fff !important;
  border-radius: 16rpx !important;
  font-size: 28rpx !important;
  border: none !important;
  margin: 0 !important;
  padding: 0 !important;
}

.empty-btn::after {
  border: none !important;
}

.report-header {
  margin-bottom: 28rpx;
}

.report-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #1e293b;
  line-height: 1.35;
}

.report-date {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #64748b;
}

.section-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #475569;
  margin-bottom: 16rpx;
}

.kpi-row {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.kpi-card {
  flex: 1;
  min-width: 200rpx;
  background: #ffffff;
  border-radius: 16px;
  padding: 16px;
  box-sizing: border-box;
  box-shadow: 0 4rpx 24rpx rgba(15, 23, 42, 0.06);
}

.kpi-card.kpi-net {
  flex-basis: 100%;
}

.tap-card:active {
  opacity: 0.92;
  transform: scale(0.99);
}

.kpi-icon {
  font-size: 32rpx;
  line-height: 1;
}

.kpi-label {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #64748b;
}

.kpi-value {
  display: block;
  margin-top: 12rpx;
  font-size: 32px;
  font-weight: 700;
  color: #0f172a;
  line-height: 1.2;
  word-break: break-all;
}

.kpi-value.tone-pos {
  color: #15803d;
}

.kpi-value.tone-neg {
  color: #dc2626;
}

.kpi-hint {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.ai-section {
  margin-bottom: 24rpx;
}

.ai-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 16rpx;
}

.ai-box {
  background: #ffffff;
  border-radius: 16px;
  padding: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(15, 23, 42, 0.06);
  box-sizing: border-box;
}

.ai-loading {
  color: #64748b;
  font-size: 28rpx;
  line-height: 1.6;
}

.ai-error {
  display: block;
  font-size: 24rpx;
  color: #b45309;
  margin-bottom: 16rpx;
}

.ai-body {
  display: block;
  font-size: 28rpx;
  line-height: 1.75;
  color: #334155;
  white-space: pre-wrap;
  word-break: break-word;
}

.footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 1rpx solid #e2e8f0;
  box-sizing: border-box;
}

.footer-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.footer-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  margin: 0;
  padding: 0;
}

.footer-btn::after {
  border: none;
}

.footer-btn.primary {
  background: linear-gradient(135deg, #1e3a8a 0%, #2563eb 100%);
  color: #ffffff;
}

.footer-btn.secondary {
  background: #f1f5f9;
  color: #1e3a8a;
}

.tap-soft:active {
  opacity: 0.9;
}

.popup-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(15, 23, 42, 0.45);
  z-index: 100;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.popup-panel {
  width: 100%;
  max-height: 62vh;
  background: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  box-shadow: 0 -8rpx 40rpx rgba(15, 23, 42, 0.12);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.popup-head {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx 16rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.popup-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
}

.popup-close {
  font-size: 36rpx;
  color: #94a3b8;
  padding: 8rpx 16rpx;
  line-height: 1;
}

.popup-scroll {
  max-height: 50vh;
  padding: 8rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.popup-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.popup-row:last-child {
  border-bottom: none;
}

.popup-name {
  flex: 1;
  font-size: 28rpx;
  color: #334155;
  line-height: 1.5;
}

.popup-amt {
  flex-shrink: 0;
  font-size: 28rpx;
  font-weight: 600;
  color: #0f172a;
}

.popup-empty {
  display: block;
  padding: 48rpx 0;
  text-align: center;
  color: #94a3b8;
  font-size: 28rpx;
}

@media (min-width: 520px) {
  .kpi-card.kpi-net {
    flex: 1;
    flex-basis: auto;
  }
}

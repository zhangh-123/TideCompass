<view class="report-page">
  <view wx:if="{{pageLoading}}" class="page-loading">
    <text>正在加载报告…</text>
  </view>

  <view wx:elif="{{loadError}}" class="empty-state">
    <text class="empty-title">暂时无法展示报告</text>
    <text class="empty-desc">{{loadError}}</text>
    <button class="empty-btn tap-soft" hover-class="none" bindtap="onGoAssessment">去财务体检</button>
  </view>

  <view wx:else class="main-body">
    <view class="report-header">
      <text class="report-title">财务健康诊断报告</text>
      <text class="report-date">{{reportDateText}}</text>
    </view>

    <view class="section-label">核心指标驾驶舱</view>
    <view class="kpi-row">
      <view class="kpi-card tap-card" data-kind="assets" bindtap="onKpiTap">
        <text class="kpi-icon">📦</text>
        <text class="kpi-label">总资产</text>
        <text class="kpi-value">{{totalAssetsFmt}}</text>
        <text class="kpi-hint">点击查看明细</text>
      </view>
      <view class="kpi-card tap-card" data-kind="liabilities" bindtap="onKpiTap">
        <text class="kpi-icon">⚠️</text>
        <text class="kpi-label">总负债</text>
        <text class="kpi-value">{{totalLiabilitiesFmt}}</text>
        <text class="kpi-hint">点击查看明细</text>
      </view>
      <view class="kpi-card kpi-net">
        <text class="kpi-icon">⚖️</text>
        <text class="kpi-label">净资产</text>
        <text class="kpi-value tone-{{netWorthTone}}">{{netWorthFmt}}</text>
        <text class="kpi-hint">资产 − 负债</text>
      </view>
    </view>

    <view class="ai-section">
      <text class="ai-title">📊 智能财务分析报告</text>
      <view wx:if="{{aiLoading}}" class="ai-box ai-loading">
        <text>正在生成个性化分析，请稍候…</text>
      </view>
      <view wx:else class="ai-box">
        <text wx:if="{{aiError}}" class="ai-error">{{aiError}}</text>
        <text class="ai-body">{{aiAnalysis}}</text>
      </view>
    </view>
  </view>

  <view wx:if="{{!pageLoading && !loadError}}" class="footer safe-bottom">
    <view class="footer-actions">
      <button class="footer-btn secondary tap-soft" hover-class="none" bindtap="onReenterAssessment">
        重新录入
      </button>
      <button
        wx:if="{{showCompleteBtn}}"
        class="footer-btn primary tap-soft"
        hover-class="none"
        loading="{{submitting}}"
        disabled="{{submitting}}"
        bindtap="onComplete"
      >
        完成体检，进入首页
      </button>
      <button wx:else class="footer-btn primary tap-soft" hover-class="none" bindtap="onGoHome">
        返回首页
      </button>
    </view>
  </view>

  <view
    wx:if="{{popupVisible}}"
    class="popup-mask tap-soft"
    bindtap="closePopup"
    catchtouchmove="noop"
  >
    <view class="popup-panel" catchtap="noop">
      <view class="popup-head">
        <text class="popup-title">{{popupTitle}}</text>
        <text class="popup-close tap-soft" bindtap="closePopup">✕</text>
      </view>
      <scroll-view class="popup-scroll" scroll-y show-scrollbar="{{false}}">
        <block wx:if="{{popupItems.length}}">
          <view wx:for="{{popupItems}}" wx:key="index" class="popup-row">
            <text class="popup-name">{{item.name}}</text>
            <text class="popup-amt">{{item.valueFmt}}</text>
          </view>
        </block>
        <text wx:else class="popup-empty">暂无明细数据</text>
      </scroll-view>
    </view>
  </view>
</view>

<view class="page">
  <view wx:if="{{loading}}" class="state">加载中…</view>

  <view wx:elif="{{emptyText && users.length === 0}}" class="state muted">{{emptyText}}</view>

  <scroll-view wx:else class="list" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="row" wx:for="{{users}}" wx:key="_id">
      <view class="meta">
        <text class="phone">{{item.phoneDisplay}}</text>
        <text class="sub">{{item.openIdShort}} · {{item.createdDisplay}}</text>
      </view>
      <text wx:if="{{item.isProtectedAdmin}}" class="admin-tag">admin</text>
      <button
        wx:else
        class="del"
        size="mini"
        type="warn"
        data-id="{{item._id}}"
        data-phone="{{item.phone}}"
        bindtap="onDeleteTap"
      >
        删除
      </button>
    </view>
    <view class="bottom-safe" />
  </scroll-view>
</view>

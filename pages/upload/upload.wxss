.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background: #f4f7fb;
}
.title-card,
.card {
  background: #fff;
  border-radius: 16rpx;
  border: 1rpx solid #e5e7eb;
  padding: 22rpx;
  margin-bottom: 18rpx;
}
.title { display: block; font-size: 34rpx; font-weight: 700; color: #0f172a; }
.sub { display: block; margin-top: 10rpx; font-size: 24rpx; color: #64748b; line-height: 1.45; }
.actions { display: flex; gap: 16rpx; margin-bottom: 18rpx; }
.btn { flex: 1; border-radius: 12rpx; background: #2563eb; color: #fff; font-size: 28rpx; }
.card-title { display: block; margin-bottom: 14rpx; font-size: 28rpx; font-weight: 600; color: #1e293b; }
.file-row { display: flex; align-items: center; justify-content: space-between; gap: 16rpx; padding: 12rpx 0; border-bottom: 1rpx solid #f1f5f9; }
.file-row:last-child { border-bottom: none; }
.file-main { flex: 1; min-width: 0; }
.file-name { display: block; font-size: 26rpx; color: #334155; }
.file-id { display: block; margin-top: 6rpx; font-size: 20rpx; color: #94a3b8; word-break: break-all; }
.mini { background: #eff6ff !important; color: #1d4ed8 !important; }
.status { font-size: 24rpx; color: #475569; }
.row { display: flex; align-items: flex-start; gap: 12rpx; padding: 14rpx 0; border-bottom: 1rpx solid #f1f5f9; }
.row:last-child { border-bottom: none; }
.row-main { flex: 1; }
.row-line { display: block; font-size: 25rpx; color: #334155; }
.row-sub { display: block; margin-top: 5rpx; font-size: 22rpx; color: #94a3b8; }
.import-btn { margin-top: 16rpx; border-radius: 12rpx; background: #059669 !important; color: #fff !important; }

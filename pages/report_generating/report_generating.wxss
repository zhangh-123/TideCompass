.page {
  min-height: 100vh;
  background: #f8fafc;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 32rpx;
  box-sizing: border-box;
}

.card {
  width: 100%;
  max-width: 680rpx;
  background: #fff;
  border: 1rpx solid #e2e8f0;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.05);
  padding: 40rpx 32rpx;
  box-sizing: border-box;
  text-align: center;
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #1e293b;
}

.sub {
  display: block;
  margin-top: 14rpx;
  font-size: 26rpx;
  color: #64748b;
  line-height: 1.55;
}

.dot-wrap {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  margin: 32rpx 0 20rpx;
}

.dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #1e3a8a;
  animation: blink 1.2s infinite ease-in-out;
}

.dot.d2 {
  animation-delay: 0.2s;
}

.dot.d3 {
  animation-delay: 0.4s;
}

.hint {
  display: block;
  font-size: 24rpx;
  color: #94a3b8;
}

@keyframes blink {
  0%,
  80%,
  100% {
    opacity: 0.2;
    transform: translateY(0);
  }
  40% {
    opacity: 1;
    transform: translateY(-4rpx);
  }
}

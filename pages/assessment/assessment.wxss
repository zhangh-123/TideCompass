.shell {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f8fafc;
  font-family:
    Inter,
    -apple-system,
    BlinkMacSystemFont,
    'PingFang SC',
    'Source Han Sans SC',
    'Noto Sans SC',
    sans-serif;
}

.head-safe {
  background: #ffffff;
  border-bottom: 1rpx solid #e2e8f0;
}

.progress-head {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
  padding: 16rpx 24rpx 10rpx;
}

.progress-head.simple {
  justify-content: space-between;
}

.head-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1e293b;
}

.ghost-btn {
  margin: 0 !important;
  padding: 0 20rpx !important;
  height: 56rpx !important;
  line-height: 1.2 !important;
  font-size: 24rpx !important;
  color: #475569 !important;
  background: #f1f5f9 !important;
  border-radius: 16rpx !important;
  border: none !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  box-sizing: border-box !important;
}

.ghost-btn::after {
  border: none !important;
}

.chat {
  flex: 1;
  height: 0;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
}

.chat-end {
  height: 32rpx;
}

.msg-row {
  display: flex;
  margin-bottom: 18rpx;
}

.msg-row.user {
  justify-content: flex-end;
}

.msg-row.assistant {
  justify-content: flex-start;
}

.bubble-wrap {
  max-width: 80%;
  position: relative;
}

.bubble {
  padding: 16rpx 22rpx;
  border-radius: 18rpx;
  font-size: 30rpx;
  line-height: 1.5;
  word-break: break-word;
  white-space: pre-wrap;
  box-sizing: border-box;
  position: relative;
}

.bubble.user {
  background: #eff6ff;
  color: #1e3a8a;
  border-top-right-radius: 8rpx;
  box-shadow: 0 4rpx 14rpx rgba(30, 58, 138, 0.08);
}

.bubble.assistant {
  background: #f1f5f9;
  color: #1e293b;
  border-top-left-radius: 8rpx;
  box-shadow: 0 4rpx 14rpx rgba(15, 23, 42, 0.08);
}

.bubble-text {
  font-weight: 400;
}

.caret {
  margin-left: 4rpx;
  color: #1e3a8a;
  font-weight: 600;
  animation: caret-blink 1s step-end infinite;
}

@keyframes caret-blink {
  50% {
    opacity: 0;
  }
}

.complete-panel {
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 1rpx solid #e2e8f0;
}

.complete-tip {
  display: block;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.next-step-btn {
  width: 100%;
  height: 88rpx;
  line-height: 1.2;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 500;
  background: linear-gradient(135deg, #1e3a8a 0%, #2563eb 100%);
  color: #ffffff;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.next-step-btn::after {
  border: none;
}

.composer {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  padding: 10px 16px calc(10px + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 1rpx solid #e2e8f0;
}

.icon-btn {
  flex-shrink: 0;
  margin: 0 !important;
  width: 72rpx !important;
  height: 72rpx !important;
  line-height: 72rpx !important;
  padding: 0 !important;
  font-size: 30rpx !important;
  border-radius: 18rpx !important;
  background: #f1f5f9 !important;
  color: #1e3a8a !important;
  border: none !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  box-sizing: border-box !important;
}

.icon-btn::after {
  border: none !important;
}

.safe-bottom {
  flex-shrink: 0;
}

.composer-input {
  flex: 1;
  width: 0;
  height: 72rpx;
  min-height: 72rpx;
  max-height: 72rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #1e293b;
  background: #f1f5f9;
  border-radius: 40rpx;
  border: 2rpx solid transparent;
  box-sizing: border-box;
  line-height: 72rpx;
  overflow: hidden;
}

.composer-input.is-focus {
  border-color: #1e3a8a;
  background: #ffffff;
  box-shadow: 0 0 0 3rpx rgba(30, 58, 138, 0.12);
}

.send-btn {
  flex-shrink: 0;
  margin: 0 !important;
  height: 72rpx !important;
  line-height: 1.2 !important;
  width: 120rpx !important;
  min-width: 120rpx !important;
  padding: 0 !important;
  font-size: 28rpx !important;
  font-weight: 500;
  border-radius: 12rpx !important;
  background: #1e3a8a !important;
  color: #ffffff !important;
  border: none !important;
  text-align: center !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  box-sizing: border-box !important;
}

.send-btn::after {
  border: none !important;
}

.send-btn.is-disabled {
  background: #e5e7eb !important;
  color: #94a3b8 !important;
}

.tap-blend:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.head-sub-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 24rpx 16rpx;
}

.head-sub-title {
  font-size: 28rpx;
  line-height: 1.4;
  color: #64748b;
  font-weight: 500;
}

.empty-tip-center {
  text-align: center;
  font-size: 24rpx;
  color: #94a3b8;
  padding: 14rpx 0 8rpx;
}

.bubble.assistant::before {
  content: '';
  position: absolute;
  left: -6rpx;
  top: 18rpx;
  width: 12rpx;
  height: 12rpx;
  background: #f1f5f9;
  transform: rotate(45deg);
}

.bubble.user::before {
  content: '';
  position: absolute;
  right: -6rpx;
  top: 18rpx;
  width: 12rpx;
  height: 12rpx;
  background: #eff6ff;
  transform: rotate(45deg);
}

.composer-shortcuts {
  display: flex;
  gap: 8rpx;
  flex-shrink: 0;
}

.composer-main {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 10px;
}

.emoji-panel {
  background: #ffffff;
  border-top: 1rpx solid #e2e8f0;
  padding: 10rpx 16px calc(10rpx + env(safe-area-inset-bottom));
}

.emoji-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.emoji-item {
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  font-size: 34rpx;
  border-radius: 12rpx;
  background: #f1f5f9;
}

.file-card {
  background: #ffffff;
  border: 1rpx solid #e2e8f0;
  border-radius: 18rpx;
  padding: 16rpx 20rpx;
  box-shadow: 0 4rpx 14rpx rgba(15, 23, 42, 0.08);
}

.file-card:active {
  transform: scale(0.99);
  opacity: 0.92;
}

.file-card.user {
  background: #eff6ff;
  border-color: #bfdbfe;
}

.file-tag {
  font-size: 22rpx;
  color: #64748b;
  display: block;
  margin-bottom: 6rpx;
}

.file-name {
  font-size: 26rpx;
  color: #1e293b;
  font-weight: 500;
  display: block;
}

.file-meta {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #94a3b8;
  display: block;
}

.review-mask {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 99;
  padding: 24rpx;
  box-sizing: border-box;
}

.review-modal {
  width: 100%;
  max-width: 680rpx;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-sizing: border-box;
}

.review-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 10rpx;
}

.review-hint {
  display: block;
  font-size: 24rpx;
  line-height: 1.55;
  color: #64748b;
  margin-bottom: 16rpx;
  padding: 14rpx 16rpx;
  background: #f1f5f9;
  border-radius: 12rpx;
  border: 1rpx solid #e2e8f0;
}

.review-input {
  width: 100%;
  min-height: 260rpx;
  max-height: 520rpx;
  padding: 16rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #1e293b;
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  border-radius: 12rpx;
  line-height: 1.5;
}

.review-actions {
  margin-top: 18rpx;
  display: flex;
  gap: 12rpx;
}

.review-btn {
  flex: 1;
  margin: 0 !important;
  height: 72rpx !important;
  line-height: 1.2 !important;
  border-radius: 12rpx !important;
  font-size: 28rpx !important;
  border: none !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  box-sizing: border-box !important;
}

.review-btn.ghost {
  background: #f1f5f9 !important;
  color: #475569 !important;
}

.review-btn.primary {
  background: #1e3a8a !important;
  color: #ffffff !important;
}

.review-btn::after {
  border: none !important;
}

@media (prefers-color-scheme: dark) {
  .shell,
  .head-safe,
  .complete-panel,
  .composer,
  .emoji-panel {
    background: #0f172a;
  }

  .head-safe,
  .complete-panel,
  .composer,
  .emoji-panel {
    border-color: #334155;
  }

  .head-title,
  .bubble.assistant,
  .file-name,
  .composer-input {
    color: #e2e8f0;
  }

  .head-sub-title,
  .complete-tip,
  .file-meta,
  .empty-tip-center {
    color: #94a3b8;
  }

  .ghost-btn,
  .icon-btn,
  .composer-input,
  .bubble.assistant,
  .file-card,
  .emoji-item {
    background: #1e293b !important;
    color: #e2e8f0 !important;
  }

  .bubble.user,
  .file-card.user {
    background: rgba(30, 58, 138, 0.35);
    color: #e2e8f0;
    border-color: rgba(59, 130, 246, 0.4);
  }

  .bubble.assistant::before {
    background: #1e293b;
  }

  .bubble.user::before {
    background: rgba(30, 58, 138, 0.35);
  }

  .composer-input.is-focus {
    background: #0f172a;
  }

  .send-btn.is-disabled {
    background: #475569 !important;
    color: #cbd5e1 !important;
  }

  .review-modal {
    background: #1e293b;
  }

  .review-title,
  .review-hint,
  .review-input {
    color: #e2e8f0;
  }

  .review-hint {
    background: #0f172a;
    border-color: #334155;
    color: #94a3b8;
  }

  .review-input {
    background: #0f172a;
    border-color: #334155;
  }
}

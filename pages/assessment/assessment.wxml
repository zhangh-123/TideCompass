<view class="shell">
  <view class="head-safe">
    <view class="progress-head simple">
      <text class="head-title">{{title}}</text>
      <button class="ghost-btn tap-blend" size="mini" hover-class="none" bindtap="onExit">退出</button>
    </view>
    <view class="head-sub-row">
      <text class="head-sub-title">财务体检 · 大约5分钟</text>
    </view>
  </view>

  <scroll-view
    class="chat"
    scroll-y
    show-scrollbar="{{false}}"
    scroll-with-animation
    scroll-into-view="{{scrollIntoView}}"
    style="padding-bottom: {{chatBottomPad}}px;"
  >
    <block wx:for="{{messages}}" wx:key="id">
      <view id="msg-{{item.id}}" class="msg-row {{item.role}}">
        <view class="bubble-wrap {{item.role}}">
          <view
            wx:if="{{item.messageType === 'file'}}"
            class="bubble {{item.role}}"
          >
            <text class="bubble-text">（此前上传的文件记录；请改用文字说明具体金额与名称，例如：度小满 欠款 5000 元）</text>
          </view>
          <view wx:else class="bubble {{item.role}}">
            <text class="bubble-text">{{item.content}}</text>
          </view>
        </view>
      </view>
    </block>
    <view wx:if="{{aiTyping}}" class="msg-row assistant">
      <view class="bubble-wrap assistant">
        <view class="bubble assistant">
          <text class="bubble-text">正在思考中…</text>
          <text class="caret">|</text>
        </view>
      </view>
    </view>
    <view id="chat-end" class="chat-end"></view>
  </scroll-view>

  <view wx:if="{{showGenerateButton}}" class="complete-panel safe-bottom">
    <text class="complete-tip">财务情况已盘点完毕，可生成财务体检报告。</text>
    <button class="next-step-btn tap-blend" hover-class="none" bindtap="onGenerateReport" loading="{{generating}}" disabled="{{generating}}">生成报告</button>
  </view>

  <view
    wx:if="{{!showGenerateButton}}"
    class="composer safe-bottom composer-fixed"
    style="bottom: {{keyboardHeight}}px;"
  >
    <view class="composer-main composer-main-full">
      <textarea
        class="composer-input {{composerFocus ? 'is-focus' : ''}}"
        placeholder="{{composerPlaceholder}}"
        maxlength="800"
        auto-height="{{true}}"
        cursor-spacing="28"
        show-confirm-bar="{{false}}"
        confirm-type="send"
        adjust-position="{{false}}"
        bindkeyboardheightchange="onComposerKeyboardHeight"
        value="{{composerSeed}}"
        bindinput="onDraftInput"
        bindfocus="onComposerFocus"
        bindblur="onComposerBlur"
        bindconfirm="onSend"
      />
      <button
        class="send-btn tap-blend {{sendDisabled || aiTyping || generating || sending ? 'is-disabled' : ''}}"
        hover-class="none"
        disabled="{{sendDisabled || aiTyping || generating || sending}}"
        bindtap="onSend"
      >
        {{sending ? '发送中…' : '发送'}}
      </button>
    </view>
  </view>
</view>

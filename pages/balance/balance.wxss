.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #eef2f7;
}

.main {
  flex: 1;
  height: 0;
  padding: 16rpx 24rpx 0;
  box-sizing: border-box;
}

.safe-row {
  padding-bottom: 8rpx;
}

.toolbar {
  display: flex;
  justify-content: flex-end;
}

.import-btn {
  font-size: 24rpx !important;
  line-height: 1.4 !important;
  padding: 8rpx 20rpx !important;
  background: #fff !important;
  color: #2563eb !important;
  border: 1rpx solid #bfdbfe !important;
}

.card {
  background: #fff;
  border-radius: 18rpx;
  padding: 28rpx 26rpx;
  border: 1rpx solid #e5e7eb;
  margin-bottom: 20rpx;
}

.hero-row {
  margin-bottom: 22rpx;
}

.hero-row:last-child {
  margin-bottom: 0;
}

.hero-row.highlight {
  padding-top: 18rpx;
  border-top: 1rpx solid #f1f5f9;
}

.hero-label {
  display: block;
  font-size: 24rpx;
  color: #64748b;
  margin-bottom: 6rpx;
}

.hero-num {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #0f172a;
  letter-spacing: 0.5rpx;
}

.hero-num.nw {
  color: #2563eb;
}

.hero-cn {
  display: block;
  font-size: 22rpx;
  color: #475569;
  margin-top: 8rpx;
  line-height: 1.45;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 16rpx;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.row:last-child {
  border-bottom: none;
}

.row-main {
  flex: 1;
  min-width: 0;
}

.row-name {
  display: block;
  font-size: 28rpx;
  color: #334155;
}

.row-val {
  display: block;
  font-size: 26rpx;
  color: #64748b;
  margin-top: 6rpx;
}

.row-actions {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.icon-btn {
  font-size: 34rpx;
  padding: 8rpx;
  color: #64748b;
}

.icon-btn.danger {
  color: #dc2626;
}

.empty {
  font-size: 26rpx;
  color: #94a3b8;
}

.chart-hint {
  display: block;
  font-size: 22rpx;
  color: #94a3b8;
  margin-bottom: 12rpx;
  line-height: 1.4;
}

.chart-box {
  width: 100%;
  height: 380rpx;
  position: relative;
}

.chart-ec {
  width: 100%;
  height: 100%;
}

.bottom-spacer {
  height: 160rpx;
}

.footer {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #e5e7eb;
}

.footer-btn {
  flex: 1;
  font-size: 28rpx !important;
  border-radius: 14rpx !important;
}

.footer-btn.primary {
  background: #2563eb !important;
  color: #fff !important;
}

.footer-btn.secondary {
  background: #f1f5f9 !important;
  color: #334155 !important;
}

.mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(15, 23, 42, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  padding: 40rpx;
  box-sizing: border-box;
}

.dialog {
  width: 100%;
  max-width: 620rpx;
}

.dlg-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #0f172a;
  margin-bottom: 28rpx;
}

.field {
  margin-bottom: 24rpx;
}

.field-label {
  display: block;
  font-size: 24rpx;
  color: #64748b;
  margin-bottom: 10rpx;
}

.field-input {
  background: #f8fafc;
  border-radius: 12rpx;
  padding: 20rpx 22rpx;
  font-size: 28rpx;
  border: 1rpx solid #e2e8f0;
}

.dlg-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 12rpx;
}

.dlg-btn {
  flex: 1;
  font-size: 28rpx !important;
  border-radius: 12rpx !important;
}

.dlg-btn.ghost {
  background: #f1f5f9 !important;
  color: #475569 !important;
}

.dlg-btn.primary {
  background: #2563eb !important;
  color: #fff !important;
}

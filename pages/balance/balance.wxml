<view class="page">
  <scroll-view class="main" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="toolbar safe-row">
      <button class="import-btn" size="mini" bindtap="importFromReport" loading="{{importing}}">
        从最新体检导入
      </button>
    </view>

    <view class="hero card">
      <view class="hero-row">
        <text class="hero-label">总资产（元）</text>
        <text class="hero-num">{{totalAssetsFmt}}</text>
        <text class="hero-cn">{{totalAssetsCn}}</text>
      </view>
      <view class="hero-row">
        <text class="hero-label">总负债（元）</text>
        <text class="hero-num">{{totalLiabilitiesFmt}}</text>
        <text class="hero-cn">{{totalLiabilitiesCn}}</text>
      </view>
      <view class="hero-row highlight">
        <text class="hero-label">净值（元）</text>
        <text class="hero-num nw">{{netWorthFmt}}</text>
        <text class="hero-cn">{{netWorthCn}}</text>
      </view>
    </view>

    <view class="section card">
      <text class="section-title">资产列表</text>
      <view wx:if="{{assets.length}}" class="list">
        <view class="row" wx:for="{{assets}}" wx:key="index">
          <view class="row-main">
            <text class="row-name">{{item.name}}</text>
            <text class="row-val">{{item.valueFmt}} 元</text>
          </view>
          <view class="row-actions">
            <text class="icon-btn" data-kind="asset" data-index="{{index}}" bindtap="onEdit">✎</text>
            <text class="icon-btn danger" data-kind="asset" data-index="{{index}}" bindtap="onDelete">🗑</text>
          </view>
        </view>
      </view>
      <text wx:else class="empty">暂无资产项</text>
    </view>

    <view class="section card">
      <text class="section-title">负债列表</text>
      <view wx:if="{{liabilities.length}}" class="list">
        <view class="row" wx:for="{{liabilities}}" wx:key="index">
          <view class="row-main">
            <text class="row-name">{{item.name}}</text>
            <text class="row-val">{{item.valueFmt}} 元</text>
          </view>
          <view class="row-actions">
            <text class="icon-btn" data-kind="liability" data-index="{{index}}" bindtap="onEdit">✎</text>
            <text class="icon-btn danger" data-kind="liability" data-index="{{index}}" bindtap="onDelete">🗑</text>
          </view>
        </view>
      </view>
      <text wx:else class="empty">暂无负债项</text>
    </view>

    <view class="section card chart-card">
      <text class="section-title">净值走势（近 6 个月 · 估算）</text>
      <text class="chart-hint">根据当前净值与记账流水收支按月倒推，仅供参考。</text>
      <view class="chart-box">
        <ec-canvas
          id="balance-trend"
          class="chart-ec"
          style="width:100%;height:100%;display:block;"
          canvas-id="balance-trend-canvas"
          echarts="{{ echartsLib }}"
          ec="{{ ec }}"
        />
      </view>
    </view>

    <view class="bottom-spacer" />
  </scroll-view>

  <view class="footer safe-bottom">
    <button class="footer-btn primary" bindtap="openAddAsset">添加资产</button>
    <button class="footer-btn secondary" bindtap="openAddLiability">添加负债</button>
  </view>

  <view class="mask" wx:if="{{dialogVisible}}" catchtouchmove="noop">
    <view class="dialog card">
      <text class="dlg-title">{{dialogTitle}}</text>
      <view class="field">
        <text class="field-label">名称</text>
        <input class="field-input" placeholder="如：房产、存款" value="{{dialogName}}" bindinput="onNameInput" />
      </view>
      <view class="field">
        <text class="field-label">金额（元）</text>
        <input class="field-input" type="digit" placeholder="0" value="{{dialogAmount}}" bindinput="onAmountInput" />
      </view>
      <view class="dlg-actions">
        <button class="dlg-btn ghost" bindtap="closeDialog">取消</button>
        <button class="dlg-btn primary" bindtap="confirmDialog">确定</button>
      </view>
    </view>
  </view>
</view>

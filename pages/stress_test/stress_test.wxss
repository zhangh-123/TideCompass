.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background: #f4f7fb;
}
.card {
  background: #fff;
  border: 1rpx solid #e5e7eb;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 18rpx;
}
.title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #0f172a;
}
.big {
  display: block;
  margin-top: 10rpx;
  font-size: 44rpx;
  font-weight: 700;
  color: #2563eb;
}
.sub {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #64748b;
}
.label {
  display: block;
  margin-top: 12rpx;
  margin-bottom: 8rpx;
  font-size: 24rpx;
  color: #334155;
}
.input {
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
  border-radius: 12rpx;
  padding: 16rpx 18rpx;
  font-size: 30rpx;
}

.inline-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.radio-row {
  margin-top: 12rpx;
  display: flex;
  gap: 22rpx;
  color: #334155;
  font-size: 26rpx;
}

.ev-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  border: 1rpx solid #e2e8f0;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-top: 10rpx;
  background: #fff;
}

.ev-main {
  flex: 1;
  min-width: 0;
}

.ev-title {
  display: block;
  font-size: 27rpx;
  color: #0f172a;
}

.ev-sub {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #64748b;
}

.custom-list {
  margin-top: 12rpx;
}

.custom-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 1rpx dashed #e2e8f0;
  padding: 12rpx 2rpx;
}

.custom-text {
  color: #334155;
  font-size: 24rpx;
}

.custom-del {
  color: #ef4444;
  font-size: 24rpx;
}
.run-btn,
.vip-btn {
  margin-top: 16rpx;
  border-radius: 12rpx;
  background: #2563eb !important;
  color: #fff !important;
}
.result {
  display: block;
  margin-top: 14rpx;
  font-size: 32rpx;
  color: #0f172a;
  font-weight: 600;
}

.series-list {
  margin-top: 12rpx;
  border-top: 1rpx solid #e2e8f0;
}

.series-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
  color: #334155;
  font-size: 24rpx;
}
.desc {
  display: block;
  margin-top: 10rpx;
  font-size: 25rpx;
  color: #475569;
  line-height: 1.5;
}

<view class="page">
  <view class="field">
    <text class="label">日期</text>
    <picker mode="date" value="{{date}}" start="2000-01-01" end="2099-12-31" bindchange="onDateChange">
      <view class="picker-val">{{date}}</view>
    </picker>
  </view>

  <view class="field">
    <text class="label">类型</text>
    <view class="type-switch">
      <button
        class="type-btn {{txType === 'expense' ? 'active exp' : ''}}"
        bindtap="setExpense"
      >
        支出
      </button>
      <button
        class="type-btn {{txType === 'income' ? 'active inc' : ''}}"
        bindtap="setIncome"
      >
        收入
      </button>
    </view>
  </view>

  <view class="field">
    <text class="label">类别</text>
    <picker mode="selector" range="{{categories}}" value="{{categoryIndex}}" bindchange="onCategoryChange">
      <view class="picker-val">{{categories[categoryIndex]}}</view>
    </picker>
  </view>

  <view class="field">
    <text class="label">金额（元）</text>
    <input class="input" type="digit" placeholder="必填" value="{{amount}}" bindinput="onAmountInput" />
  </view>

  <view class="field">
    <text class="label">备注（可选）</text>
    <input class="input" maxlength="120" placeholder="简短说明" value="{{note}}" bindinput="onNoteInput" />
  </view>

  <view wx:if="{{budgetTip}}" class="budget-mini-tip">{{budgetTip}}</view>

  <button class="save-btn" type="primary" loading="{{saving}}" disabled="{{saving}}" bindtap="onSave">
    保存
  </button>
</view>

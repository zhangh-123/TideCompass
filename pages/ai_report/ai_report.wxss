.page { min-height: 100vh; padding: 24rpx; box-sizing: border-box; background: #f4f7fb; }
.card { background:#fff; border:1rpx solid #e5e7eb; border-radius:16rpx; padding:22rpx; margin-bottom:18rpx; }
.title { display:block; font-size:30rpx; font-weight:600; color:#0f172a; margin-bottom:10rpx; }
.desc,.line { display:block; color:#475569; line-height:1.5; font-size:24rpx; margin-bottom:6rpx; }
.btn { margin-top:12rpx; border-radius:12rpx; background:#2563eb !important; color:#fff !important; }
.btn.secondary { background:#eff6ff !important; color:#1d4ed8 !important; }
.head-row { display:flex; align-items:center; gap:8rpx; margin-bottom:8rpx; }
.sub { color:#94a3b8; font-size:22rpx; }
.actions { margin-top:12rpx; display:flex; gap:10rpx; }
.small { flex:1; background:#eff6ff !important; color:#1d4ed8 !important; border-radius:10rpx; font-size:24rpx !important; }

.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f0f4f8;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 20rpx;
  border: 1rpx solid #e8e8e8;
}

.month-summary .sum-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.month-summary .sum-row.bold {
  border-top: 1rpx solid #f1f5f9;
  margin-top: 8rpx;
  padding-top: 20rpx;
}

.sum-label {
  font-size: 28rpx;
  color: #64748b;
}

.sum-val {
  font-size: 30rpx;
  font-weight: 600;
}

.sum-val.inc {
  color: #059669;
}

.sum-val.exp {
  color: #dc2626;
}

.list-scroll {
  flex: 1;
  height: 0;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.date-head {
  font-size: 24rpx;
  color: #94a3b8;
  padding: 16rpx 8rpx 8rpx;
}

.swipe-wrap {
  position: relative;
  overflow: hidden;
  border-radius: 14rpx;
  margin-bottom: 14rpx;
}

.swipe-delete {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 140rpx;
  background: #ef4444;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  z-index: 0;
}

.swipe-front {
  position: relative;
  z-index: 1;
  background: #fff;
  border: 1rpx solid #eef2f7;
}

.row-main {
  display: flex;
  align-items: flex-start;
  padding: 22rpx 20rpx;
  gap: 16rpx;
}

.cat-badge {
  width: 48rpx;
  height: 48rpx;
  border-radius: 10rpx;
  background: #e0e7ff;
  color: #4338ca;
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.row-text {
  flex: 1;
  min-width: 0;
}

.cat-name {
  display: block;
  font-size: 28rpx;
  color: #1e293b;
}

.note {
  display: block;
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.amt {
  font-size: 30rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.amt.inc {
  color: #059669;
}

.amt.exp {
  color: #dc2626;
}

.empty {
  text-align: center;
  color: #94a3b8;
  padding: 80rpx 0;
  font-size: 28rpx;
}

.scroll-bottom {
  height: calc(24rpx + env(safe-area-inset-bottom));
}
